  <script>
    // Bidirectional Conversions functions
    let updating = false;
    function updateBidirectional(source) {
      if (updating) return;
      updating = true;
      const row = source.closest('tr');
      const factor = parseFloat(row.getAttribute('data-factor'));
      if (isNaN(factor)) { updating = false; return; }
      const impInput = row.querySelector('.imperial');
      const metInput = row.querySelector('.metric');
      if (source.classList.contains('imperial')) {
        const impVal = parseFloat(impInput.value) || 0;
        metInput.value = (impVal * factor).toFixed(4);
      } else {
        const metVal = parseFloat(metInput.value) || 0;
        impInput.value = factor !== 0 ? (metVal / factor).toFixed(4) : '';
      }
      updating = false;
    }
    function updateTemperature(source) {
      if (updating) return;
      updating = true;
      const row = source.closest('tr');
      const impInput = row.querySelector('.imperial');
      const metInput = row.querySelector('.metric');
      if (source.classList.contains('imperial')) {
        const f = parseFloat(impInput.value);
        metInput.value = !isNaN(f) ? ((f - 32) * 5/9).toFixed(2) : '';
      } else {
        const c = parseFloat(metInput.value);
        impInput.value = !isNaN(c) ? (c * 9/5 + 32).toFixed(2) : '';
      }
      updating = false;
    }
  </script>

