  <script>
    /* Garden Bed Calculators */
    function calculateBedMetrics() {
      let resultsHTML = "<h3>Bed Metrics</h3>";
      const lengthIn = parseFloat(document.getElementById('bedLengthIn').value);
      const widthIn = parseFloat(document.getElementById('bedWidthIn').value);
      const depthIn = parseFloat(document.getElementById('bedDepthIn').value);
      if (!isNaN(lengthIn) && !isNaN(widthIn) && !isNaN(depthIn) && (lengthIn || widthIn || depthIn)) {
        const areaIn = lengthIn * widthIn;
        const volIn = areaIn * depthIn;
        resultsHTML += `<p><strong>Inches:</strong> Area = ${areaIn.toFixed(2)} in², Volume = ${volIn.toFixed(2)} in³</p>`;
      }
      const lengthFt = parseFloat(document.getElementById('bedLengthFt').value);
      const widthFt = parseFloat(document.getElementById('bedWidthFt').value);
      const depthFt = parseFloat(document.getElementById('bedDepthFt').value);
      if (!isNaN(lengthFt) && !isNaN(widthFt) && !isNaN(depthFt) && (lengthFt || widthFt || depthFt)) {
        const areaFt = lengthFt * widthFt;
        const volFt = areaFt * depthFt;
        resultsHTML += `<p><strong>Feet:</strong> Area = ${areaFt.toFixed(2)} ft², Volume = ${volFt.toFixed(2)} ft³</p>`;
      }
      const lengthM = parseFloat(document.getElementById('bedLengthM').value);
      const widthM = parseFloat(document.getElementById('bedWidthM').value);
      const depthM = parseFloat(document.getElementById('bedDepthM').value);
      if (!isNaN(lengthM) && !isNaN(widthM) && !isNaN(depthM) && (lengthM || widthM || depthM)) {
        const areaM = lengthM * widthM;
        const volM = areaM * depthM;
        resultsHTML += `<p><strong>Meters:</strong> Area = ${areaM.toFixed(4)} m², Volume = ${volM.toFixed(4)} m³</p>`;
      }
      const lengthCm = parseFloat(document.getElementById('bedLengthCm').value);
      const widthCm = parseFloat(document.getElementById('bedWidthCm').value);
      const depthCm = parseFloat(document.getElementById('bedDepthCm').value);
      if (!isNaN(lengthCm) && !isNaN(widthCm) && !isNaN(depthCm) && (lengthCm || widthCm || depthCm)) {
        const areaCm = lengthCm * widthCm;
        const volCm = areaCm * depthCm;
        resultsHTML += `<p><strong>Centimeters:</strong> Area = ${areaCm.toFixed(2)} cm², Volume = ${volCm.toFixed(2)} cm³</p>`;
      }
      document.getElementById('bedResults').innerHTML = resultsHTML;
    }
    function calculateBedAdjustment() {
      const unit = document.getElementById('bedUnit').value;
      let conv = 1;
      if (unit === "ft") conv = 0.3048;
      else if (unit === "in") conv = 0.0254;
      else if (unit === "cm") conv = 0.01;
      const length = parseFloat(document.getElementById('bed_currentLength').value) || 0;
      const width = parseFloat(document.getElementById('bed_currentWidth').value) || 0;
      const depth = parseFloat(document.getElementById('bed_currentDepth').value) || 0;
      const increase = parseFloat(document.getElementById('bed_increasePercent').value) || 0;
      const Lm = length * conv;
      const Wm = width * conv;
      const Dm = depth * conv;
      const factor = 1 + (increase / 100);
      const newLm = Lm * factor;
      const newWm = Wm * factor;
      const newDm = Dm * factor;
      const convBack = 1 / conv;
      const finalL = newLm * convBack;
      const finalW = newWm * convBack;
      const finalD = newDm * convBack;
      const areaCalc = finalL * finalW;
      const volumeCalc = areaCalc * finalD;
      const resultHTML = `<h4>Adjusted Bed Metrics (${unit}):</h4>
                          <p>New Length: ${finalL.toFixed(3)} ${unit}</p>
                          <p>New Width: ${finalW.toFixed(3)} ${unit}</p>
                          <p>New Depth: ${finalD.toFixed(3)} ${unit}</p>
                          <p>Area: ${areaCalc.toFixed(4)} ${unit}²</p>
                          <p>Volume: ${volumeCalc.toFixed(4)} ${unit}³</p>`;
      document.getElementById('bedAdjResults').innerHTML = resultHTML;
    }
    
    /* Fertilizer Calculators */
    function calculateFertilizerValue() {
      const usTons = parseFloat(document.getElementById('fvUsTons').value) || 0;
      const percent = parseFloat(document.getElementById('fvPercent').value) || 0;
      let area = parseFloat(document.getElementById('fvArea').value) || 1;
      const unit = document.getElementById('fvAreaUnit').value;
      if (unit === "ha") area *= 2.47105;
      else if (unit === "ft2") area /= 43560;
      const totalLb = usTons * 2000 * (percent / 100);
      const lbPerAcre = totalLb / area;
      document.getElementById('fvResult').textContent = lbPerAcre.toFixed(2) + " lb/acre";
    }
    function calculateFertilizerAdjustment() {
      const usTons = parseFloat(document.getElementById('adj_fvUsTons').value) || 0;
      const basePercent = parseFloat(document.getElementById('adj_fvPercent').value) || 0;
      const increase = parseFloat(document.getElementById('adj_increasePercent').value) || 0;
      let area = parseFloat(document.getElementById('adj_fvArea').value) || 1;
      const unit = document.getElementById('adjAreaUnit').value;
      if (unit === "ha") area *= 2.47105;
      else if (unit === "ft2") area /= 43560;
      const adjustedPercent = basePercent * (1 + increase / 100);
      const totalLb = usTons * 2000 * (adjustedPercent / 100);
      const lbPerAcre = totalLb / area;
      document.getElementById('adj_fvResult').textContent = lbPerAcre.toFixed(2) + " lb/acre";
    }
    function calculatePlantNumber() {
      let area = parseFloat(document.getElementById('pnArea').value) || 0;
      const density = parseFloat(document.getElementById('pnDensity').value) || 0;
      const areaUnit = document.getElementById('pnAreaUnit').value;
      if (areaUnit === "acre") area *= 4046.86;
      else if (areaUnit === "ha") area *= 10000;
      let densityHa = density;
      const densUnit = document.getElementById('pnDensityUnit').value;
      if (densUnit === "plants/acre") densityHa *= 2.47105;
      const areaHa = area / 10000;
      const totalPlants = areaHa * densityHa;
      document.getElementById('pnResult').textContent = totalPlants.toFixed(0) + " plants";
    }
    function convertPPMtoLbN() {
      const ppm = parseFloat(document.getElementById('ppmInput').value) || 0;
      const lbN = ppm / 1200;
      document.getElementById('ppmResult').textContent = lbN.toFixed(4) + " lb";
    }
    function calculateLbNVolume() {
      let lbN = parseFloat(document.getElementById('lbNInput').value) || 0;
      let volume = parseFloat(document.getElementById('volumeInput').value) || 0;
      const nutUnit = document.getElementById('nutrientUnit').value;
      const volUnit = document.getElementById('volumeUnit').value;
      if (nutUnit === "kg") lbN *= 2.20462;
      else if (nutUnit === "oz") lbN /= 16;
      if (volUnit === "liter") volume *= 0.264172;
      else if (volUnit === "m3") volume *= 264.172;
      const total = lbN * volume;
      document.getElementById('lbNVolumeResult').textContent = total.toFixed(4) + " lb";
    }
    function calculateFertilizerMixture() {
      const percent = parseFloat(document.getElementById('fmPercent').value) || 0;
      let weightInput = parseFloat(document.getElementById('fmWeight').value) || 0;
      const unit = document.getElementById('weightUnit').value;
      let weightLb;
      if (unit === "lb") weightLb = weightInput;
      else if (unit === "kg") weightLb = weightInput * 2.20462;
      else if (unit === "g") weightLb = weightInput / 453.592;
      else if (unit === "oz") weightLb = weightInput / 16;
      const pureN_lb = percent > 0 ? weightLb * (100 / percent) : 0;
      let result;
      if (unit === "lb") result = pureN_lb;
      else if (unit === "kg") result = pureN_lb / 2.20462;
      else if (unit === "g") result = pureN_lb * 453.592;
      else if (unit === "oz") result = pureN_lb * 16;
      document.getElementById('fmResult').textContent = result.toFixed(2) + " " + unit;
    }
    
    /* Additional Fertilizer & Nutrient Calculators */
    function calcCostOfNutrient() {
      const priceBag = parseFloat(document.getElementById('costBagPrice').value) || 0;
      const bagSize = parseFloat(document.getElementById('costBagSize').value) || 1;
      const bagUnit = document.getElementById('costBagSizeUnit').value;
      let bagSizeKG = bagSize;
      if(bagUnit === "lb") bagSizeKG = bagSize * 0.453592;
      else if(bagUnit === "g") bagSizeKG = bagSize / 1000;
      else if(bagUnit === "oz") bagSizeKG = bagSize / 35.274;
      const prop = parseFloat(document.getElementById('costNutrientProp').value) || 0;
      let area = parseFloat(document.getElementById('costArea').value) || 0;
      const areaUnit = document.getElementById('costAreaUnit').value;
      if(areaUnit === "ft2") area = area * 0.092903;
      else if(areaUnit === "acre") area = area * 4046.86;
      const rate = parseFloat(document.getElementById('costAppRate').value) || 0;
      const rateUnit = document.getElementById('costRateUnit').value;
      let rateKG;
      if(rateUnit === "kg/100m2") rateKG = rate;
      else if(rateUnit === "g/100m2") rateKG = rate / 1000;
      else if(rateUnit === "lb/100ft2") rateKG = rate * 0.453592 * (100/9.2903);
      const totalNutrient = (rateKG * area) / 100;
      const fertReq = prop > 0 ? totalNutrient / (prop / 100) : 0;
      let html = `<p><strong>Total Nutrient Required:</strong> ${totalNutrient.toFixed(2)} kg</p>`;
      html += `<p><strong>Fertilizer Required:</strong> ${fertReq.toFixed(2)} kg</p>`;
      html += `<p><strong>Total Cost:</strong> $${(fertReq / bagSizeKG * priceBag).toFixed(2)}</p>`;
      document.getElementById('costNutrientResults').innerHTML = html;
    }
    function calcFertAppRates() {
      const prop = parseFloat(document.getElementById('appNutrientProp').value) || 0;
      const rate = parseFloat(document.getElementById('appDesiredRate').value) || 0;
      const rateUnit = document.getElementById('appDesiredRateUnit').value;
      let rateKG;
      if(rateUnit === "kg/100m2") rateKG = rate;
      else if(rateUnit === "g/100m2") rateKG = rate / 1000;
      else if(rateUnit === "lb/100ft2") rateKG = rate * 0.453592 * (100/9.2903);
      let area = parseFloat(document.getElementById('appArea').value) || 0;
      const areaUnit = document.getElementById('appAreaUnit').value;
      if(areaUnit === "ft2") area = area * 0.092903;
      else if(areaUnit === "acre") area = area * 4046.86;
      else if(areaUnit === "ha") area = area * 10000;
      const totalFertilizer = (rateKG * area) / 100;
      const totalNutrient = totalFertilizer * (prop / 100);
      let html = `<p><strong>Total Fertilizer:</strong> ${totalFertilizer.toFixed(2)} kg</p>`;
      html += `<p><strong>Total Nutrient:</strong> ${totalNutrient.toFixed(2)} kg</p>`;
      document.getElementById('appRatesResults').innerHTML = html;
    }
    function calcFertCostPerKg() {
      const costBag = parseFloat(document.getElementById('costBag').value) || 0;
      const bagSize = parseFloat(document.getElementById('costBagKg').value) || 1;
      const bagUnit = document.getElementById('costBagKgUnit').value;
      let bagSizeKG = bagSize;
      if(bagUnit === "lb") bagSizeKG = bagSize * 0.453592;
      else if(bagUnit === "g") bagSizeKG = bagSize / 1000;
      else if(bagUnit === "oz") bagSizeKG = bagSize / 35.274;
      const prop = parseFloat(document.getElementById('costBagProp').value) || 0;
      const totalNutrientInBag = bagSizeKG * (prop / 100);
      const costPerKg = totalNutrientInBag > 0 ? costBag / totalNutrientInBag : 0;
      let html = `<p><strong>Total Nutrient in Bag:</strong> ${totalNutrientInBag.toFixed(2)} kg</p>`;
      html += `<p><strong>Cost per kg Nutrient:</strong> $${costPerKg.toFixed(2)}/kg</p>`;
      document.getElementById('costPerKgResults').innerHTML = html;
    }
    function calcFertTotalWeights() {
      const prop = parseFloat(document.getElementById('totWProportion').value) || 0;
      const weight = parseFloat(document.getElementById('totWWeight').value) || 0;
      const totalNutrient = weight * (prop / 100);
      let html = `<p><strong>Total Nutrient:</strong> ${totalNutrient.toFixed(2)} kg</p>`;
      document.getElementById('totWResults').innerHTML = html;
    }
    function calcNutrientWeights() {
      const prop = parseFloat(document.getElementById('nutWeightProp').value) || 0;
      const baseWeight = parseFloat(document.getElementById('nutWeightKg').value) || 0;
      const unit = document.getElementById('nutWeightUnit').value;
      let baseKG = baseWeight;
      if(unit === "lb") baseKG = baseWeight * 0.453592;
      else if(unit === "g") baseKG = baseWeight / 1000;
      else if(unit === "oz") baseKG = baseWeight / 35.274;
      const nutrientKG = baseKG * (prop / 100);
      let result;
      if(unit === "kg") result = nutrientKG.toFixed(2) + " kg";
      else if(unit === "lb") result = (nutrientKG * 2.20462).toFixed(2) + " lb";
      else if(unit === "g") result = (nutrientKG * 1000).toFixed(2) + " g";
      else if(unit === "oz") result = (nutrientKG * 35.274).toFixed(2) + " oz";
      document.getElementById('nutWeightResults').innerHTML = `<p><strong>Nutrient Weight:</strong> ${result}</p>`;
    }
    function calcNutrientBagWeights() {
      const bagSize = parseFloat(document.getElementById('bagSizeCalc').value) || 0;
      const bagUnit = document.getElementById('bagSizeUnit').value;
      let bagKG = bagSize;
      if(bagUnit === "lb") bagKG = bagSize * 0.453592;
      else if(bagUnit === "g") bagKG = bagSize / 1000;
      else if(bagUnit === "oz") bagKG = bagSize / 35.274;
      const prop = parseFloat(document.getElementById('bagNutrientProp').value) || 0;
      const totalNutrientKG = bagKG * (prop / 100);
      let converted;
      if(bagUnit === "kg") converted = totalNutrientKG.toFixed(2) + " kg";
      else if(bagUnit === "lb") converted = (totalNutrientKG * 2.20462).toFixed(2) + " lb";
      else if(bagUnit === "g") converted = (totalNutrientKG * 1000).toFixed(2) + " g";
      else if(bagUnit === "oz") converted = (totalNutrientKG * 35.274).toFixed(2) + " oz";
      document.getElementById('bagNutrientResults').innerHTML = `<p><strong>Nutrient Weight:</strong> ${converted}</p>`;
    }
    
    /* Imperial per Acre Conversions */
    function calcAcreConversion() {
