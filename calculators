  <!-- Light Conversion Tools Script -->
  <script>
    /* Intensity to PAR */
    function convertIntensity() {
      const radOutside = parseFloat(document.getElementById('radiationOutsideW').value);
      const transmission = parseFloat(document.getElementById('transmissionIntensity').value);
      const outputField = document.getElementById('parInsideUmol');
      if (isNaN(radOutside) || isNaN(transmission)) {
        outputField.value = "Invalid input";
        return;
      }
      const fraction = transmission / 100.0;
      const insideW = radOutside * fraction;
      const insideUmol = insideW * 4.57;
      outputField.value = insideUmol.toFixed(2);
    }
    
    /* Joules/cm² to DLI */
    function calcJoulesToPPFD() {
      // This function converts joules/cm² to DLI in mol/m²/day
      const joules = parseFloat(document.getElementById('joulesInputCalc').value) || 0;
      const dli = joules * 10000 / 217000;
      document.getElementById('dliOutputCalc').value = (Math.round(dli * 1000) / 1000).toFixed(3);
    }
    
    /* Lux & Foot-Candle Conversions */
    const LUX_TO_PPFD_FACTOR = 54;
    function convertLuxToPPFD() {
      const lux = parseFloat(document.getElementById('luxInput').value);
      if (isNaN(lux)) {
        document.getElementById('luxResult').textContent = "Please enter a valid Lux value.";
        return;
      }
      const ppfd = lux / LUX_TO_PPFD_FACTOR;
      document.getElementById('luxResult').textContent = `${lux} Lux ≈ ${ppfd.toFixed(2)} µmol/m²/s PPFD`;
    }
    function convertPPFDToLux() {
      const ppfd = parseFloat(document.getElementById('ppfdInput').value);
      if (isNaN(ppfd)) {
        document.getElementById('luxResult').textContent = "Please enter a valid PPFD value (in the PPFD field above).";
        return;
      }
      const lux = ppfd * LUX_TO_PPFD_FACTOR;
      document.getElementById('luxResult').textContent = `${ppfd} µmol/m²/s PPFD ≈ ${lux.toFixed(2)} Lux`;
    }
    function convertFcToPPFD() {
      const fc = parseFloat(document.getElementById('fcInput').value);
      if (isNaN(fc)) {
        document.getElementById('luxResult').textContent = "Please enter a valid Foot-Candle value.";
        return;
      }
      const lux = fc * 10.764;
      const ppfd = lux / LUX_TO_PPFD_FACTOR;
      document.getElementById('luxResult').textContent = `${fc} Foot-Candles ≈ ${ppfd.toFixed(2)} µmol/m²/s PPFD`;
    }
    function convertPPFDToFc() {
      const ppfd = parseFloat(document.getElementById('ppfdInput').value);
      if (isNaN(ppfd)) {
        document.getElementById('luxResult').textContent = "Please enter a valid PPFD value (in the PPFD field above).";
        return;
      }
      const lux = ppfd * LUX_TO_PPFD_FACTOR;
      const fc = lux / 10.764;
      document.getElementById('luxResult').textContent = `${ppfd} µmol/m²/s PPFD ≈ ${fc.toFixed(2)} Foot-Candles`;
    }
    
    /* Lumens to PPF Converter */
    var spdData = [
      [43.4782608695652, "Natural Daylight 6500K", "6500k-ppf-d65"],
      [28.9136150234742, "Halogen Lamp 3000K", "3000k-ppf-halogen"],
      [58.0260303687636, "High CRI LED 6500K", "6000k-ppf"],
      [56.1085972850679, "High CRI LED 4000K", "4000k-ppf"],
      [52.5557011795544, "High CRI LED 3000K", "3000k-ppf"],
      [74.5889387144992, "Low CRI LED 6500K", "6000k-ppf-lc"],
      [62.3559498956159, "Low CRI LED 3500K", "3500k-ppf-lc"],
      [77.079295154185, "HPS 2000K", "2000k-ppf-hps"],
      [55.092987804878, "CMH 3000K", "3000k-ppf-cmh"],
      [74.1128205128205, "Fluorescent Lamp 5000K", "5000k-ppf-fl"],
      [13.0122950819672, "Monochromatic Red LED 650 nm", "650-ppf-red"],
      [8.65410497981157, "Monochromatic Blue LED 450 nm", "450-ppf-blue"],
      [11.2700369913687, "Red + Blue LED 450+650 nm", "450-650-ppf-red-blue"],
      [38.9265536723164, "Red + Blue + White LED 450+650nm+3500K", "450+650+white-ppf"]
    ];
    function populateSPD() {
      var spdSelect = document.getElementById("spdSelect");
      for(var z = 0; z < spdData.length; z++) {
        var option = document.createElement("option");
        option.text = spdData[z][1];
        spdSelect.add(option);
      }
    }
    populateSPD();
    function calcLumensToPPF() {
      var x = parseFloat(document.getElementById("x").value) || 0;
      var spdSelect = document.getElementById("spdSelect");
      var spdIndex = spdSelect.selectedIndex;
      var factor = spdData[spdIndex][0];
      var result = Math.round(x / factor * 100) / 100;
      document.getElementById("result").innerHTML = result + " umol/s";
    }
    
    /* Micromoles to Moles */
    function calcMicromolesToMoles() {
      const micromoles = parseFloat(document.getElementById('micromolesInput').value) || 0;
      const moles = micromoles / 1e6;
      document.getElementById('molesOutput').value = moles;
    }
    
    /* SUM/DLI Converter */
    function convertSumDLI() {
      const radOutside = parseFloat(document.getElementById('radiationOutsideJoule').value);
      const transmission = parseFloat(document.getElementById('transmissionSum').value);
      const outputField = document.getElementById('parInsideMol');
      if (isNaN(radOutside) || isNaN(transmission)) {
        outputField.value = "Invalid input";
        return;
      }
      const fraction = transmission / 100.0;
      const joulePerM2 = radOutside * 10000;
      const totalUmol = joulePerM2 * fraction * 4.57;
      const totalMol = totalUmol / 1e6;
      outputField.value = totalMol.toFixed(2);
    }
  </script>
