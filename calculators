      quinoa: { ppm: 34, citation: "https://pubmed.ncbi.nlm.nih.gov/32738703/" },
      radish: { ppm: 5000, citation: "https://pubmed.ncbi.nlm.nih.gov/11299341/" },
      sorghum: { ppm: 34000, citation: "https://www.semanticscholar.org/paper/03914ddfc030b8b89c16095087d6f5fa65dbe4b6" },
      sugarbeet: { ppm: 30000, citation: "https://www.ncbi.nlm.nih.gov/pmc/articles/PMC9082935/" },
      tomato: { ppm: 30000, citation: "https://www.semanticscholar.org/paper/41d3fe0191c60b9f6bdd3113d27863264b3d4b42" },
      wheat: { ppm: 5.1, citation: "https://www.semanticscholar.org/paper/26fca08d5b9f74e7a4a97f215a10b3ab37f15410" }
    };
    function populateCropDropdown() {
      const cropSelect = document.getElementById("crop");
      cropSelect.innerHTML = "";
      const sortedCrops = Object.keys(cropData).sort();
      sortedCrops.forEach(crop => {
        let option = document.createElement("option");
        option.value = crop;
        option.textContent = crop.charAt(0).toUpperCase() + crop.slice(1);
        cropSelect.appendChild(option);
      });
    }
    populateCropDropdown();
    
    function calculateDilution() {
      const waterVolume = parseFloat(document.getElementById("waterVolumeHP").value);
      const unit = document.getElementById("unitHP").value;
      const strength = parseFloat(document.getElementById("h2o2Strength").value);
      const crop = document.getElementById("crop") ? document.getElementById("crop").value : null;
      
      if (isNaN(waterVolume) || waterVolume <= 0) {
        document.getElementById("output").innerHTML = "<p style='color:red;'>Please enter a valid water volume.</p>";
        return;
      }
      
      const waterInLiters = unit === "gallons" ? waterVolume * 3.785 : waterVolume;
      const ppm = crop ? cropData[crop].ppm : 50;
      const citation = crop ? cropData[crop].citation : "#";
      
      let requiredPeroxideML = (ppm * waterInLiters) / (strength * 10);
      let requiredGrams = requiredPeroxideML * 1.01;
      let requiredDrops = Math.max(1, Math.round(requiredPeroxideML * 20));
      
      let displayAmount = requiredPeroxideML >= 1 
        ? `${requiredPeroxideML.toFixed(2)} mL / ${requiredGrams.toFixed(2)} g`
        : `~${requiredDrops} drops (~${(requiredGrams * 1000).toFixed(2)} mg). Consider using a syringe or pre-dilution.`;
      
      document.getElementById("output").innerHTML = `
        <h3>Results</h3>
        <p>Add <strong>${displayAmount}</strong> of ${strength}% hydrogen peroxide to ${waterVolume} ${unit} of water.</p>
        <p class="citation"><strong>Reference:</strong> <a href="${citation}" target="_blank">Study Link</a></p>`;}
  </script>
