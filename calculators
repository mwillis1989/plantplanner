  <!-- Heating and Venting Script -->
  <script>
    function calcGlazingHeatLoss() {
      let area = parseFloat(document.getElementById('gmArea').value) || 0;
      const areaUnit = document.getElementById('gmAreaUnit').value;
      if(areaUnit === "m2") area = area * 10.7639;
      else if(areaUnit === "yd2") area = area * 9;
      const U = parseFloat(document.getElementById('gmUValue').value) || 0;
      let inside = parseFloat(document.getElementById('gmInsideTemp').value) || 0;
      let outside = parseFloat(document.getElementById('gmOutsideTemp').value) || 0;
      const tempUnit = document.getElementById('gmInsideTempUnit').value;
      if(tempUnit === "C") {
        inside = inside * 9/5 + 32;
        outside = outside * 9/5 + 32;
      }
      const deltaT = inside - outside;
      const loss = area * U * deltaT;
      document.getElementById('gmHeatLoss').textContent = loss.toFixed(2) + " BTUH";
    }
    
    function calcGreenhouseHeatLoss() {
      let height = parseFloat(document.getElementById('ghlHeight').value) || 0;
      let length = parseFloat(document.getElementById('ghlLength').value) || 0;
      const heightUnit = document.getElementById('ghlHeightUnit').value;
      const lengthUnit = document.getElementById('ghlLengthUnit').value;
      if(heightUnit === "m") height = height * 3.28084;
      else if(heightUnit === "yd") height = height * 3;
      if(lengthUnit === "m") length = length * 3.28084;
      else if(lengthUnit === "yd") length = length * 3;
      const area = height * length;
      let inside = parseFloat(document.getElementById('ghlInsideTemp').value) || 0;
      let outside = parseFloat(document.getElementById('ghlOutsideTemp').value) || 0;
      const tempUnit = document.getElementById('ghlInsideTempUnit').value;
      if(tempUnit === "C") {
        inside = inside * 9/5 + 32;
        outside = outside * 9/5 + 32;
      }
      const deltaT = inside - outside;
      const U = parseFloat(document.getElementById('ghlUValue').value) || 0;
      const loss = area * deltaT * U;
      document.getElementById('ghlHeatLoss').textContent = loss.toFixed(2) + " BTUH";
    }
    
    function calcGreenhouseHeatNeeds() {
      let width = parseFloat(document.getElementById('ghWidth').value) || 0;
      let length = parseFloat(document.getElementById('ghLength').value) || 0;
      const widthUnit = document.getElementById('ghWidthUnit').value;
      const lengthUnit = document.getElementById('ghLengthUnit').value;
      if(widthUnit === "m") width = width * 3.28084;
      else if(widthUnit === "yd") width = width * 3;
      if(lengthUnit === "m") length = length * 3.28084;
      else if(lengthUnit === "yd") length = length * 3;
      const area = width * length;
      let inside = parseFloat(document.getElementById('ghInsideTemp').value) || 0;
      let outside = parseFloat(document.getElementById('ghOutsideTemp').value) || 0;
      const tempUnit = document.getElementById('ghInsideTempUnit').value;
      if(tempUnit === "C") {
        inside = inside * 9/5 + 32;
        outside = outside * 9/5 + 32;
      }
      const deltaT = inside - outside;
      const U = parseFloat(document.getElementById('ghUValue').value) || 0;
      const BTU = area * deltaT * U;
      document.getElementById('ghHeatNeeds').textContent = BTU.toFixed(2) + " BTU";
    }
    
    function calcVentilationNeeds() {
      let length = parseFloat(document.getElementById('gvLength').value) || 0;
      let width = parseFloat(document.getElementById('gvWidth').value) || 0;
      const lengthUnit = document.getElementById('gvLengthUnit').value;
      const widthUnit = document.getElementById('gvWidthUnit').value;
      if(lengthUnit === "m") length = length * 3.28084;
      else if(lengthUnit === "yd") length = length * 3;
      if(widthUnit === "m") width = width * 3.28084;
      else if(widthUnit === "yd") width = width * 3;
      const area = length * width;
      const cfmUnit = document.getElementById('gvCfmUnit').value;
      let cfmPerFt2 = parseFloat(document.getElementById('gvCfmPerFt2').value) || 0;
      if(cfmUnit === "cfm/m2") cfmPerFt2 = cfmPerFt2 / 0.092903;
      else if(cfmUnit === "cfm/yd2") cfmPerFt2 = cfmPerFt2 / 1.196;
      const totalCFM = area * cfmPerFt2;
      document.getElementById('gvVentilation').textContent = totalCFM.toFixed(0) + " cfm";
    }
  </script>

</body>

















































<body>
  <h1>Light Conversion Tools</h1>
  <div id="calcBlock5">
    
    <!-- Intensity to PAR Converter -->
    <details id="intensityToPAR">
      <summary>Intensity to PAR Converter with Transmission <span class="toggle-text">(Open/Close)</span></summary>
      <p>Convert external radiation (W/m²) to inside PAR (µmol/m²/s) using a transmission factor.</p>
