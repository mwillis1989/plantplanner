      <label>CFM per Area Unit:
        <select id="gvCfmUnit">
          <option value="cfm/ft2" selected>cfm/ft²</option>
          <option value="cfm/m2">cfm/m²</option>
          <option value="cfm/yd2">cfm/yd²</option>
        </select>
      </label>
      <input type="number" id="gvCfmPerFt2" placeholder="e.g., 8" step="any">
