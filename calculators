      <br>
      <label for="parInsideUmol">PAR inside (µmol/m²/s):</label>
      <input type="text" id="parInsideUmol" readonly>
    </details>
    
    <!-- Joules/cm² to DLI Converter -->
    <details id="joulesToDLI">
      <summary>Joules/cm² to DLI (moles/day) Converter <span class="toggle-text">(Open/Close)</span></summary>
      <p>Convert radiation in J/cm² to a daily light integral (mol/m²/day).</p>
      <label for="joulesInputCalc">Radiation (J/cm²):</label>
      <input type="number" id="joulesInputCalc" step="any" placeholder="e.g., 0.5">
      <br>
      <button onclick="calcJoulesToDLI()">Convert</button>
      <br>
      <label for="dliOutputCalc">DLI (mol/m²/day):</label>
      <input type="text" id="dliOutputCalc" readonly>
    </details>
    
    <!-- Lux & Foot-Candle Conversions -->
    <details id="luxConversions">
      <summary>Lux &amp; Foot-Candle Conversions <span class="toggle-text">(Open/Close)</span></summary>
      <p>Convert between Lux, Foot-Candles, and PPFD (≈54 Lux per µmol/m²/s).</p>
